# ── LLM Provider ────────────────────────────────────────────────────────────────
# Choose: openai | anthropic | portkey
LLM_PROVIDER=portkey

# Model name — change freely without touching code
# For Portkey, use the virtual key / model path from your Portkey dashboard
LLM_MODEL_NAME=@anthropic-474a72/claude-sonnet-4-6

# API Keys
OPENAI_API_KEY=sk-proj-xxxx
ANTHROPIC_API_KEY=sk-ant-xxxx
PORTKEY_API_KEY=your-portkey-api-key

# ── Embedding ────────────────────────────────────────────────────────────────────
# Embedding provider is independent of LLM_PROVIDER: openai | portkey
# For portkey: set EMBEDDING_MODEL to @<openai-virtual-key-slug>/text-embedding-3-small
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ── Chunking ─────────────────────────────────────────────────────────────────────
# Choose: fixed | recursive | sentence
CHUNKING_STRATEGY=recursive
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── Chroma ───────────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=poc_documents

# ── LLM Safety Limits ────────────────────────────────────────────────────────────
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=30
